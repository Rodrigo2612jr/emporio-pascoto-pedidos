# ============================================
# Variáveis de Ambiente - Empório Pascoto
# ============================================
# Para desenvolvimento local, NÃO precisa configurar nada.
# O sistema usa SQLite local automaticamente (data/pedidos.db).
#
# Para produção (Vercel + Turso), configure:
# 1. Crie conta gratuita em https://turso.tech
# 2. Crie um banco de dados
# 3. Copie a URL e o Token
# 4. Configure no painel da Vercel: Settings → Environment Variables

TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu-token-aqui
